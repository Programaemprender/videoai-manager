# VideoAI Manager Configuration

# Storage
VIDEO_INPUT_FOLDER=/path/to/your/videos
DATA_FOLDER=./data

# Google Drive Integration (optional)
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_ACCOUNT_EMAIL=

# Google Sheets Integration (optional)
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEET_ID=

# Facial Recognition
FACIAL_RECOGNITION_ENABLED=true
MIN_VIDEOS_FOR_NOTIFICATION=2
MIN_APPEARANCES_FOR_NOTIFICATION=3

# AI Models
YOLO_MODEL=yolov5s
CONFIDENCE_THRESHOLD=0.5

# Notifications (optional - for hosted service)
WHATSAPP_ENABLED=false
EMAIL_ENABLED=false

# Advanced (optional)
OPENAI_API_KEY=
FRAMES_TO_ANALYZE=3
PROCESSING_INTERVAL=30  # frames between analysis
